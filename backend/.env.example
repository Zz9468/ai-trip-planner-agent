
# LLM配置(OpenAI-compatible)
LLM_MODEL_ID=gpt-4o-mini
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别
LOG_LEVEL=INFO

# Unsplash API Credentials
UNSPLASH_ACCESS_KEY=""
UNSPLASH_SECRET_KEY=""

# 高德地图Web服务API配置
AMAP_API_KEY=your_amap_api_key_here

# MCP工具配置
USE_MCP_TOOLS=true
MCP_AMAP_SERVER_MODULE=app.mcp_servers.amap_server
MCP_SESSION_START_TIMEOUT_SECONDS=10
MCP_TOOL_TIMEOUT_SECONDS=30

# Redis配置
# Windows可用 Docker Desktop、WSL、Memurai 或 Redis for Windows 兼容服务启动本地Redis。
# auto: 优先使用Redis,连接失败自动回退内存版; redis: 强制Redis; memory: 只用内存版。
TRIP_JOB_BACKEND=auto
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=trip
TRIP_JOB_TTL_SECONDS=86400
TRIP_JOB_SSE_HEARTBEAT_SECONDS=15
TRIP_CACHE_ENABLED=true
TRIP_CACHE_POI_TTL_SECONDS=604800
TRIP_CACHE_WEATHER_TTL_SECONDS=21600

# LangGraph Checkpoint / 持久化状态
LANGGRAPH_CHECKPOINT_ENABLED=true
LANGGRAPH_CHECKPOINT_BACKEND=sqlite
LANGGRAPH_CHECKPOINT_DB=./data/langgraph_checkpoints.sqlite
